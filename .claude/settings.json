{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "deny": [
      "mcp__dbx__dbx_add_connection",
      "mcp__dbx__dbx_remove_connection"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if command -v powershell >/dev/null 2>&1; then powershell -NoProfile -ExecutionPolicy Bypass -File \"D:\\reverse_ENV\\.claude\\hooks\\tool-check.ps1\"; fi",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"D:\\reverse_ENV\\.claude\\hooks\\pre-tool-policy.ps1\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}

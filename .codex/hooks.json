{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"D:\\reverse_ENV\\.codex\\hooks\\session-preflight.ps1\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"D:\\reverse_ENV\\.codex\\hooks\\session-preflight.ps1\"",
            "timeout": 15,
            "statusMessage": "Running reverse_ENV Codex preflight"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"D:\\reverse_ENV\\.codex\\hooks\\pre-tool-policy.ps1\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"D:\\reverse_ENV\\.codex\\hooks\\pre-tool-policy.ps1\"",
            "timeout": 10,
            "statusMessage": "Checking reverse_ENV shell policy"
          }
        ]
      }
    ]
  }
}
